
<mujoco model="2d_cheetah">
    <compiler angle="degree" coordinate="local" inertiafromgeom="true" settotalmass="14"/>

    <option timestep="0.001" gravity="0 0 -9.81"/>

    <worldbody>
        <light cutoff="100" diffuse="1 1 1" dir="-0 0 -1.3" directional="true" exponent="1" pos="0 0 1.3" specular=".1 .1 .1"/>

        <!-- Ground -->
        <geom name="ground" type="plane" pos="0 0 0" size="40 40 1" condim="3"/>

        <!-- Body of the cheetah -->
        <body name="torso" pos="0 0 0.5">
            <joint axis="0 1 0" damping="6" name="torso" pos="0 0 0" stiffness="240" type="hinge"/>
            <geom fromto="0 0 0 0 0 0.5 " name="torso" size="0.046" type="capsule"/>
            <body name="bthigh" pos="0 0 2">
                <joint axis="0 1 0" damping="6" name="bthigh" pos="0 0 -1" stiffness="240" type="hinge"/>
                <geom  name="bthigh" pos="0 0 0" size="0.05 0.8" type="capsule"/>
            </body>
        </body>
        
    </worldbody>

    <actuator>
        <position kp="1000" joint="torso" name="torso_p"/>
        <position kp="1000" joint="bthigh" name="bthigh_p"/>
        <velocity kv="1000" joint="torso" name="torso_v"/>
        <velocity kv="1000" joint="bthigh" name="bthigh_v"/>
    </actuator>
</mujoco>